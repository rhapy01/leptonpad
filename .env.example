# LeptonPad — single root .env for local dev and Replit secrets.
# Copy to .env and fill in values.

# ── Database (required) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/leptonpad

# ── Clerk Auth (required) ────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
# Optional: proxy URL for deployed environments (Vercel/Replit). Leave empty for localhost.
# VITE_CLERK_PROXY_URL=https://your-app.vercel.app/api/__clerk
VITE_CLERK_PROXY_URL=

# ── Circle Gateway / x402 + LeptonSplit contract (REQUIRED for hackathon) ─────
# 1) Set platform wallet (receives 5% from on-chain split)
PLATFORM_WALLET_ADDRESS=0xYourPlatformWallet
# 2) Deploy: cd artifacts/api-server && pnpm run deploy-split
# 3) Backfill published paid content: pnpm run register-content
LEPTON_SPLIT_CONTRACT=0xYourDeployedSplitContract
GATEWAY_SELLER_ADDRESS=0xYourDeployedSplitContract
GATEWAY_FACILITATOR_URL=https://gateway-api-testnet.circle.com
GATEWAY_CHAIN_ID=5042002
GATEWAY_NETWORK=eip155:5042002
GATEWAY_CHAIN_NAME=arcTestnet

# Contract owner — deploys LeptonSplit and executes atomic splits after x402 settlement
SPLIT_OWNER_PRIVATE_KEY=0xYourOwnerPrivateKey

# ── In-app wallet (testnet) ───────────────────────────────────────────────────
WALLET_ENCRYPTION_SECRET=change-me-to-a-long-random-string
# Funds reader Gateway deposits (not creator payouts — split contract handles those)
TREASURY_PRIVATE_KEY=0xYourTreasuryPrivateKey

# ── Development (keep false for hackathon demo) ────────────────────────────────
MOCK_PAYMENTS=false

# ── Vercel production ───────────────────────────────────────────────────────
# Set in Vercel Project → Settings → Environment Variables (Production + Preview)
# PUBLIC_URL=https://your-app.vercel.app
# APP_URL=https://your-app.vercel.app
# VITE_CLERK_PROXY_URL=https://your-app.vercel.app/api/__clerk
# VERCEL sets VERCEL_URL automatically — used for in-app x402 gateway hops

# ── Ports (local dev) ────────────────────────────────────────────────────────
# Frontend (Vite)
PORT=25139
BASE_PATH=/
# API server (Express) — mapped to PORT at API startup
API_PORT=8787

# ── Email (Google SMTP) ──────────────────────────────────────────────────────
# Gmail / Google Workspace — use an App Password (not your login password):
# https://myaccount.google.com/apppasswords
#
# Deliverability (avoid spam):
# 1. BEST: send from your own domain via Google Workspace (noreply@yourdomain.com)
#    and add SPF + DKIM + DMARC in DNS (Google Admin → Gmail → Authenticate email).
# 2. SMTP_FROM must use the SAME address as SMTP_USER (Gmail rejects mismatched From).
# 3. For production volume, consider Resend / Postmark / Amazon SES instead of personal Gmail.
# 4. Personal Gmail caps at ~500 emails/day and often lands in Promotions/Spam for bulk mail.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=LeptonPad <your@gmail.com>
# Optional — where replies go (defaults to SMTP_USER)
SMTP_REPLY_TO=your@gmail.com
# Optional: links in welcome emails
APP_URL=http://localhost:25139
PUBLIC_URL=http://localhost:25139

# ── LLM (optional — enables AI writing/SEO; falls back to heuristics) ────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── Cloudinary (recommended for production media) ───────────────────────────────
# Single URL from Cloudinary dashboard → API Keys (preferred):
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
# Or set the three vars separately:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ── Platform admin ────────────────────────────────────────────────────────────
# Comma-separated emails auto-promoted to admin on sign-in / account creation
INITIAL_ADMIN_EMAILS=akintoyeisaac5@gmail.com

# ── Media uploads ─────────────────────────────────────────────────────────────
# Local fallback when BLOB_READ_WRITE_TOKEN is unset:
UPLOAD_DIR=./uploads
# Vercel Blob (recommended for production) — from Vercel Dashboard → Storage → Blob
# Run `vercel env pull` or paste from the store settings page.
BLOB_STORE_ID=store_...
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
