{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "deploy-split": "node ./scripts/deploy-split.mjs",
    "register-content": "node ./scripts/register-content-on-chain.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@circle-fin/x402-batching": "^3.1.2",
    "@clerk/express": "^2.1.26",
    "@x402/evm": "^2.0.0",
    "@clerk/shared": "^4.17.1",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cloudinary": "^2.6.0",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^4.1.0",
    "sanitize-html": "^2.17.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "@simplewebauthn/server": "^13.1.1",
    "viem": "^2.31.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/sanitize-html": "^2.16.0",
    "@types/node": "catalog:",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "solc": "^0.8.24",
    "thread-stream": "3.1.0"
  }
