{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "name": "lepton-pad",
  "installCommand": "corepack enable && corepack prepare pnpm@9.15.9 --activate && pnpm install --no-frozen-lockfile",
  "buildCommand": "node scripts/vercel-build.mjs",
  "outputDirectory": "artifacts/leptonpad/dist/public",
  "framework": null,
  "functions": {
    "api/index.mjs": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "artifacts/api-server/dist/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    {
      "source": "/content/:id",
      "has": [
        {
          "type": "header",
          "key": "User-Agent",
          "value": "(?i)(bot|facebookexternalhit|twitterbot|linkedinbot|slackbot|discordbot|whatsapp|telegrambot|googlebot|bingpreview|pinterest|embedly|quora link preview|vkshare|w3c_validator|redditbot)"
        }
      ],
      "destination": "/api/seo/content/:id/card"
    },
    {
      "source": "/read/:id",
      "has": [
        {
          "type": "header",
          "key": "User-Agent",
          "value": "(?i)(bot|facebookexternalhit|twitterbot|linkedinbot|slackbot|discordbot|whatsapp|telegrambot|googlebot|bingpreview|pinterest|embedly|quora link preview|vkshare|w3c_validator|redditbot)"
        }
      ],
      "destination": "/api/seo/content/:id/card"
    },
    { "source": "/((?!api/)(?!.*\\.).*)", "destination": "/index.html" }
  ],
  "build": {
    "env": {
      "PORT": "25139",
      "BASE_PATH": "/",
      "NODE_ENV": "production"
    }
  }
}
